#!/bin/sh
# Kiro Assistant — open Claude Code preloaded with the Kiro knowledge base.
# The shipped pack is read straight from /usr/share (read-only): Claude Code
# writes session state to ~/.claude, not the working dir, so no copy is needed.
# Personal knowledge the assistant is told to remember persists in
# ~/.claude/kiro-assistant — that one folder is the whole user layer to back up
# or carry to a new install.
set -eu

if ! command -v claude >/dev/null 2>&1; then
	echo "kiro-assistant: 'claude' not found. Install the claude-code package first." >&2
	exit 1
fi

mkdir -p "$HOME/.claude/kiro-assistant"
cd /usr/share/kiro-assistant
exec claude "$@"
